{
  "name": "@visualq/mcp",
  "version": "1.0.0",
  "description": "MCP server for VisualQ — qa profile (~39 tools): run_full_audit, VRT/FRT, tracking, rolling health",
  "type": "module",
  "bin": {
    "visualq-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "tools-manifest.json",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "sync-manifest": "node -e \"const m=require('./tools-manifest.json'); if(!m.tools?.length) { console.error('tools-manifest.json missing or empty'); process.exit(1) } console.log('Manifest OK:', m.tools.length, 'tools')\"",
    "skills:sync": "node packages/agent-skills/scripts/sync-skills.mjs"
  },
  "keywords": [
    "mcp",
    "visualq",
    "vrt",
    "visual-regression",
    "cursor",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abecms/visualq-mcp.git"
  },
  "homepage": "https://visualq.ai",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "~5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
